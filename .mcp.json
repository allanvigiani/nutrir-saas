{
  "mcpServers": {
    "vercel": {
      "command": "npx",
      "args": ["-y", "@vercel/mcp@latest"],
      "env": {
        "VERCEL_TOKEN": "${VERCEL_TOKEN}"
      }
    },
    "asaas": {
      "url": "https://docs.asaas.com/mcp",
      "headers": {
        "access_token": "${ASAAS_API_KEY}"
      }
    }
  }
}
