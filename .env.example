# .env.example
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Google OAuth (ONLY for Calendar integration in backend API)
# Firebase Auth Google login is configured in Firebase Console, not here.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Google Calendar Enable API URL
GOOGLE_CALENDAR_ENABLE_API_URL=
GOOGLE_OAUTH_SCOPES=

# Asaas (for payment integration)
ASAAS_WEBHOOK_TOKEN=
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=

# Super admin emails
SUPER_ADMIN_EMAILS=

# App URL
APP_URL=http://localhost:3000

# Whatsapp Base URL
VITE_WHATSAPP_BASE_URL=https://wa.me
VITE_LOGIN_HERO_IMAGE_URL=https://images.unsplash.com/photo-1512621776951-a57141f2eefd?q=80&w=2070&auto=format&fit=crop
VITE_LOGIN_AVATAR_BASE_URL=https://i.pravatar.cc/100

AXIOM_TOKEN=
AXIOM_DATASET=
NODE_ENV=

# Firebase Admin SDK — Service Account
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# PostgreSQL (Neon)
DATABASE_URL="postgresql://..."