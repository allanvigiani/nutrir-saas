{
  "cleanUrls": false,
  "trailingSlash": false,
  "toolbar": false,
  "functions": {
    "api/index.ts": {
      "includeFiles": "node_modules/.prisma/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
